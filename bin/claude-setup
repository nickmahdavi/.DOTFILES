#!/bin/bash

set -euo pipefail

# Install Claude Code if it isn't already on PATH.
if command -v claude &>/dev/null; then
    echo "Using existing Claude Code: $(command -v claude)"
else
    echo "Installing Claude Code..."
    curl -fsSL https://claude.ai/install.sh | bash
    export PATH="$HOME/.local/bin:$PATH"
fi

if ! command -v claude &>/dev/null; then
    echo "claude not found after install" >&2
    exit 1
fi

# Authenticate if not already signed in. `auth status` exits non-zero when
# logged out, so this is safe to re-run.
if claude auth status &>/dev/null; then
    echo "Already authenticated with Claude:"
    claude auth status
else
    echo "Signing in to Claude (browser)..."
    claude auth login --email "${CLAUDE_EMAIL:-nickmahda@gmail.com}"
fi

echo "Claude setup complete:"
claude auth status
