#!/bin/bash

# nickmahda@gmail.com

set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")" || exit 1
DIR=$(pwd)

if [[ "$OSTYPE" == "darwin"* ]] && ! xcode-select -p &>/dev/null; then
    echo "Installing Xcode Command Line Tools (git/clang/make)..."
    # makes `softwareupdate` list the CLT package as installable.
    touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
    label=$(softwareupdate -l 2>/dev/null \
        | grep -E 'Command Line Tools' \
        | awk -F'*' '/\*/ {print $2}' | sed -e 's/^ *Label: //' -e 's/^ *//' \
        | sort -V | tail -n1)
    if [[ -n "$label" ]]; then
        softwareupdate -i "$label" --verbose
    else
        # Fallback: GUI installer (rare; only if softwareupdate has no label).
        xcode-select --install
        echo "Finish the Command Line Tools install dialog, then re-run ./install"
        rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
        exit 1
    fi
    rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
fi

git submodule update --init --recursive

# -g also installs GUI desktop apps (skip on headless servers)
g=0  # default; otherwise `set -u` aborts at the `[[ "$g" ]]` test below
while getopts "g" o; do
    case "$o" in
        g) g=1 ;;
    esac
done

./lnfix

if [[ "$OSTYPE" == "darwin"* ]]; then
    if [[ -z "$(which brew)" ]]; then
        sudo -v
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    brew bundle

    ./macos-defaults

elif [[ "$OSTYPE" == "linux"* ]]; then
    sudo apt update
    sudo apt install -y git curl wget build-essential gh htop python3-pip tmux vim zsh

    if (( g )); then
        source "$DIR/_linux-apps.sh"
        setup_apt_repos
        install_flatpaks
        install_nerd_font
    fi
fi

# uv
command -v uv &>/dev/null || curl -LsSf https://astral.sh/uv/install.sh | sh

# nvm
export NVM_DIR="$HOME/.nvm"
if [[ ! -s "$NVM_DIR/nvm.sh" ]]; then
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash || echo "nvm install failed; skipping node install" >&2
fi
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
    nvm install node
fi

"$DIR/gh-setup" || echo "GitHub auth skipped/failed — run ./gh-setup later."
"$DIR/claude-setup" || echo "Claude setup skipped/failed — run ./claude-setup later."

echo "Done"

cd "$DIR" || exit
