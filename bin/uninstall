#!/bin/bash

# nickmahda@gmail.com
#
# Reverses what ./install (via lnfix + macos-defaults) symlinks into place.
# Only removes OUR symlinks — never touches real files — then restores any
# backups lnfix/macos-defaults made. Idempotent. Does NOT uninstall brew
# packages, nvm, or uv (use -p to also reset macOS `defaults` we wrote).

set -uo pipefail

cd "$(dirname "$(realpath "$0")")/.." || exit 1
DIR=$(pwd)

p=0  # -p also reverts the macOS `defaults write` settings
while getopts "p" o; do
    case "$o" in
        p) p=1 ;;
    esac
done

# Remove ~/.<name> only if it's a symlink we own (points into $DIR).
unlink_ours () {
    local target="$1"
    if [[ -L "$target" ]]; then
        local dest; dest="$(readlink "$target")"
        if [[ "$dest" == "$DIR"/* ]]; then
            rm -v "$target"
        else
            echo "Skipping $target (symlink not into this repo: $dest)"
        fi
    fi
}

# Restore a backup that lnfix/macos-defaults stashed in ./backup, if present
# and if nothing real is now in the way.
restore_backup () {
    local name="$1" target="$2"
    if [[ -e "$DIR/backup/$name" && ! -e "$target" ]]; then
        mv -v "$DIR/backup/$name" "$target"
    fi
}

#--- lnfix: ~/.zsh ~/.vim ~/.tmux.conf ~/.bin and each config/* as ~/.<name> ---
unlink_ours ~/.zsh
unlink_ours ~/.vim
unlink_ours ~/.tmux.conf
unlink_ours ~/.bin

for f in "$DIR"/config/*; do
    unlink_ours ~/."$(basename "$f")"
done

#--- macos-defaults: ~/.config/karabiner + VS Code user settings ---
if [[ "$OSTYPE" == "darwin"* ]]; then
    unlink_ours "$HOME/.config/karabiner"
    vscode_user="$HOME/Library/Application Support/Code/User"
    unlink_ours "$vscode_user/settings.json"
    unlink_ours "$vscode_user/keybindings.json"
fi

#--- restore anything we backed up ---
if [[ -d "$DIR/backup" ]]; then
    for b in "$DIR"/backup/*; do
        [[ -e "$b" ]] || continue
        restore_backup "$(basename "$b")" ~/."$(basename "$b")"
    done
fi

#--- optionally revert the macOS defaults we set ---
if (( p )) && [[ "$OSTYPE" == "darwin"* ]]; then
    echo "Reverting macOS defaults we wrote..."
    defaults delete -g KeyRepeat 2>/dev/null || true
    defaults delete -g InitialKeyRepeat 2>/dev/null || true
    defaults delete com.apple.dock autohide 2>/dev/null || true
    defaults delete com.apple.dock tilesize 2>/dev/null || true
    defaults delete com.apple.dock show-recents 2>/dev/null || true
    defaults delete com.googlecode.iterm2 LoadPrefsFromCustomFolder 2>/dev/null || true
    defaults delete com.googlecode.iterm2 PrefsCustomFolder 2>/dev/null || true
    killall Dock 2>/dev/null || true
    echo "Note: trackpad/iTerm/ISS keys left as-is; delete manually if needed."
fi

echo "Uninstall complete."
