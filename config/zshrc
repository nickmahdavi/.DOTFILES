#----------------------------------------#
#             INITIALIZATION             #
#----------------------------------------#

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block, everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

[ -f ~/.vars.local ] && source ~/.vars.local
[ -f ~/.vars ] && source ~/.vars

# Reuse SSH agent socket
if ! pgrep ssh-agent > /dev/null; then
    rm -f /tmp/ssh-auth-sock
    eval "$(ssh-agent -s -a /tmp/ssh-auth-sock)" > /dev/null
else
    export SSH_AUTH_SOCK=/tmp/ssh-auth-sock
fi

#----------------------------------------#
#                  ZSH                   #
#----------------------------------------#

#----- Opts -----#

unsetopt CORRECT
unsetopt CORRECTALL
unsetopt NOMATCH
setopt AUTOCD
setopt EXTENDEDGLOB
setopt HIST_IGNORE_ALL_DUPS
setopt SHARE_HISTORY
setopt MENU_COMPLETE
setopt INTERACTIVE_COMMENTS
DISABLE_CORRECTION="true"

#----- zsh prompt -----#

source ~/.zsh/powerlevel10k/powerlevel10k.zsh-theme
source ~/.p10k.zsh

#----- Completion -----#

# The following lines were added by compinstall
zstyle ':completion:*' completer _complete _expand _ignored _approximate _prefix
zstyle ':completion:*' expand prefix
zstyle ':completion:*' file-sort access
zstyle ':completion:*' group-name ''
zstyle ':completion:*' ignore-parents parent pwd directory
zstyle ':completion:*' insert-unambiguous true
zstyle ':completion:*' list-colors ''
zstyle ':completion:*' matcher-list '' 'm:{[:lower:]}={[:upper:]} m:{[:lower:][:upper:]}={[:upper:][:lower:]} r:|[._-]=* r:|=*' 'm:{[:lower:]}={[:upper:]} m:{[:lower:][:upper:]}={[:upper:][:lower:]} r:|[._-]=* r:|=* l:|=*'
zstyle ':completion:*' original false
zstyle ':completion:*' preserve-prefix '//[^/]##/'
zstyle :compinstall filename '/home/nickmahd/.zshrc'

# End of lines added by compinstall

# Compile zcompdump once per day
autoload -Uz compinit
zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
if [[ $zcompdump -nt /usr/share/zsh ]] && [[ ! $zcompdump.zwc -nt $zcompdump ]]; then
    compinit -C
else
    compinit -i -C
    [[ -f "$zcompdump" && ! -f "$zcompdump.zwc" ]] && zcompile "$zcompdump"
fi

zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.zsh/cache

zstyle ':completion:*' accept-exact-dirs true
zstyle ':completion:*:approximate:*' max-errors 3

zstyle ':completion:*:*:kill:*' menu yes select
zstyle ':completion:*:kill:*' force-list always
zstyle ':completion:*:*:kill:*:processes' list-colors '=(#b) #([0-9]#)*=0=01;31'

#----- History -----#

HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000

#----- Bindings -----#

bindkey -v
bindkey "^?" backward-delete-char
bindkey '^\\' undo
export KEYTIMEOUT=1

#----------------------------------------#
#              ZSH_PLUGINS               #
#----------------------------------------#

source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh
source ~/.zsh/zsh-history-substring-search/zsh-history-substring-search.zsh
source ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

#----- Smart Tab: accept suggestion if shown, else complete -----#

_smart_tab() {
  if [[ -n "$POSTDISPLAY" ]]; then
    zle autosuggest-accept
  else
    zle expand-or-complete
  fi
}
zle -N _smart_tab
bindkey '^I' _smart_tab

_force_complete() {
    zle expand-or-complete
}
zle -N _force_complete
bindkey '^[[Z' _force_complete

#----- Highlighters -----#

ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern)

typeset -A ZSH_HIGHLIGHT_PATTERNS
ZSH_HIGHLIGHT_PATTERNS+=('rm -rf' 'fg=white,bold,bg=red')
ZSH_HIGHLIGHT_PATTERNS+=('rm *' 'fg=white,bg=red')
ZSH_HIGHLIGHT_PATTERNS+=('rm -rf /*' 'fg=green,bold,bg=red')

# ZSH_HIGHLIGHT_STYLES[default]='fg=green' #GREENISH
# ZSH_HIGHLIGHT_STYLES[command]='fg=blue' #BLUE = 027
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=cyan,bold' #117
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=yellow,bold' #121
ZSH_HIGHLIGHT_STYLES[builtin]='fg=134'
# ZSH_HIGHLIGHT_STYLES[arg0]='fg=027'
ZSH_HIGHLIGHT_STYLES[function]='fg=cyan'

#----- Substring search -----#

bindkey '\eOA' history-substring-search-up
bindkey '\eOB' history-substring-search-down
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# ------------------------------------------------

# bun completions
[ -s "/Users/nick/.bun/_bun" ] && source "/Users/nick/.bun/_bun"

sudo () {
    if alias "$1" &>/dev/null; then
        $(alias $1 | sed -E "s/^$1='(.*)'$/\1/") "${@:2}"
    elif type $1 2>/dev/null | grep -q 'function'; then
        local arg1=$1
        shift && command sudo zsh -c "$(declare -f $arg1); $arg1 $*"
    else
        command sudo "$@"
    fi
}

colors () {
    for i in {0..255}; do
        print -Pn "%K{$i}  %k%F{$i}${(l:3::0:)i}%f " ${${(M)$((i%6)):#3}:+$'\n'};
    done
}

open () {
    if [[ "$@" ]]; then
        command open "$@" 2> /dev/null || explorer.exe "$@" 2> /dev/null
    else
        command open . 2> /dev/null || explorer.exe . 2> /dev/null
    fi
    return 0
}


