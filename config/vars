#----------------------------------------#
#                VARIABLES               #
#----------------------------------------#

export PATH=$PATH:~/.bin
export PATH=$PATH:~/.local/bin
export PATH=$PATH:~/.cargo/bin

# Default to false so `if $IS_MAC` doesn't run the empty string as a null
# command (which always succeeds) on non-Mac systems.
export IS_MAC=false
[[ $OSTYPE == "darwin"* ]] && export IS_MAC=true

if $IS_MAC && [[ -x "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    export PATH=/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH
    export HOMEBREW_AUTO_UPDATE_SECS=86400
fi

export ZSHRC=~/.zshrc
export DOT=~/.DOTFILES
export VAR=~/.vars

[ -f "/Users/nick/.ghcup/env" ] && . "/Users/nick/.ghcup/env" # ghcup-env

# pnpm
export PNPM_HOME="/Users/nick/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

export NVM_DIR="$HOME/.nvm"

# Lazy load nvm
nvm() {
    unset -f nvm
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
    nvm "$@"
}

# Lazy load node/npm/npx
node() {
    unset -f node
    nvm use default
    node "$@"
}

npm() {
    unset -f npm
    nvm use default
    npm "$@"
}

npx() {
    unset -f npx
    nvm use default
    npx "$@"
}

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

