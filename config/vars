alias eip="curl ifconfig.me"
alias att="tmux attach -t"
alias zload="source $ZSHRC"
alias dot="cd $DOT"

alias l="ls -1Frt"
alias lc="command ls"
alias ls="ls --color=auto"
alias ll="ls -AFGhlprt"
alias grep="grep --color=auto"
alias locate="locate -i"
alias activate=". ./.venv/bin/activate"

iip () { $IS_MAC && ipconfig getifaddr en0 || hostname -I ; }

f () { find . -name "*$@*" -print ; }
duck () { du -chd ${2:-1} ${1:-.} | sort -h ; }
pf () { ps aux | grep "$@" | grep -v grep ; }

swap () {
    local tmpfile=$(mktemp $(dirname "$1")/XXXXXX)
    mv "$1" "$tmpfile" && mv "$2" "$1" && mv "$tmpfile" "$2"
}

#----- SSH -----#

SSH_QUICKNAME=home
alias sshc="ssh $SSH_QUICKNAME"
alias sshl="ssh $LAMBDA_HOSTNAME"

alias ssh-micro="aws ec2-instance-connect ssh --instance-id $AWS_MICRO_INSTANCE_ID"
alias ssh-server="aws ec2-instance-connect ssh --instance-id $AWS_SERVER_INSTANCE_ID"

wifi_get () {
    if $IS_MAC; then
        # `airport` was removed in recent macOS; parse system_profiler instead.
        system_profiler SPAirPortDataType 2>/dev/null \
            | awk '/Current Network Information/{getline; gsub(/^[ \t]+|:[ \t]*$/,""); print; exit}'
    else
        iwgetid -r
    fi
}

tunnel () { ssh -fgNL $1:127.0.0.1:$1 $SSH_QUICKNAME ; }
tkill () { kill $(pf "ssh.*$1" | awk '{print $2}') ; }

#----- Python -----#

alias pip="pip3"
alias up="uv pip"
alias python="python3"

jbook () {
    mkdir -p ~/.jupyter
    local port="${1:-8888}"
    local log=~/.jupyter/jbook-"$port".log
    nohup jupyter notebook --port="$port" > "$log" 2>&1 & disown
    local i
    for i in {1..30}; do
      grep -qE 'http://(localhost|127)' "$log" && break
      sleep 0.2
    done
    grep -oE 'http://[^ ]+' "$log" | tail -1
}

jkill () {
    if [[ "$1" == "all" ]]; then
        pkill -f jupyter || echo 'No running notebooks'
        rm -f ~/.jupyter/jbook-*.log
    elif [[ -n "$1" ]]; then
        jupyter notebook stop "$1" 2>/dev/null \
          || pkill -f "jupyter-notebook.*--port=$1" \
          || echo "No notebook on port $1"
        rm -f ~/.jupyter/jbook-"$1".log
    else
        echo "specify a port / \"all\""
    fi
}

alias jlist="jupyter notebook list"

#----- Git -----#

alias g="git"

open-repo () {
    REPO_URL=$(git config remote.origin.url)
    open "${${REPO_URL/git@github.com:/https://github.com/}%%.git}"
}

#----- Vim -----#

export VIMRC=~/.vim/vimrc
export VPKG=~/.vim/pack/bundle/start
export EDITOR=vim

vim-pkg () {
    if [ -z "$1" ]; then
        echo "Must pass a package url"
    elif [ "$1" = "update" ]; then
        cd ~/.vim && git submodule update --recursive --remote
        cd --
    elif [ "$1" = "list" ]; then
        /bin/ls -1 $VPKG
    else
        cd $VPKG
        git submodule add -b master "$1"
        cd --
    fi
}

